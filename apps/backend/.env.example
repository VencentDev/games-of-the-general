# Backend runtime configuration
SERVER_PORT=8080
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/app
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# Optional JWT issuer URI for Spring resource-server style JWT validation.
# Leave this as a local/dev issuer or replace it with your production issuer.
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_ISSUER_URI=http://localhost:8081/realms/app

APP_CORS_ALLOWED_ORIGINS=http://localhost:3000

APP_RATE_LIMIT_AUTH_ENABLED=true
APP_RATE_LIMIT_AUTH_CAPACITY=60
APP_RATE_LIMIT_AUTH_REFILL_PERIOD=1m
